{
  "name": "ai-platform-frontend",
  "version": "0.0.1",
  "private": true,
  "description": "AI Open Platform Frontend - CUI (Conversational UI)",
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "pnpm --filter @aiplatform/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "ai",
    "cui",
    "chat",
    "openai",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}